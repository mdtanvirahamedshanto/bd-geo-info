{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "outDir": "dist/react/esm",
    "target": "ES2017",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "jsx": "react",
    "resolveJsonModule": true
  },
  "include": ["src/react/**/*", "src/components/**/*", "src/types/**/*", "src/utils/**/*", "src/data/**/*"]
}

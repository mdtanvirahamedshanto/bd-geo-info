{
  "name": "bd-geo-info",
  "version": "5.0.3",
  "description": "Bangladesh geo address library — division, district, upazila (thana), union, village, postal code & BBS geocode lookup with Bangla/English names. Built for JavaScript & TypeScript. Works with Node.js, React, Next.js, Vue, Nuxt, Angular, NestJS, Express, Bun, Svelte, Remix, Astro, Electron and all major JavaScript frameworks.",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/esm/react/index.js",
      "require": "./dist/react/cjs/react/index.js",
      "types": "./dist/react/types/react/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm && npm run build:types && npm run build:react:cjs && npm run build:react:esm && npm run build:react:types && node scripts/minify-json.js",
    "build:cjs": "npx tsc -p tsconfig.cjs.json",
    "build:esm": "npx tsc -p tsconfig.esm.json",
    "build:types": "npx tsc -p tsconfig.types.json",
    "build:react:cjs": "npx tsc -p tsconfig.react.cjs.json",
    "build:react:esm": "npx tsc -p tsconfig.react.esm.json",
    "build:react:types": "npx tsc -p tsconfig.react.types.json",
    "test": "jest",
    "prepare": "npm run build"
  },
  "keywords": [
    "bangladesh",
    "geo",
    "division",
    "district",
    "upazila",
    "union",
    "postcode",
    "address",
    "bangla",
    "typescript",
    "react",
    "vue",
    "angular",
    "svelte",
    "nestjs",
    "nextjs",
    "framework-agnostic"
  ],
  "author": {
    "name": "Md Tanvir Ahamed Shanto",
    "email": "mdtanvirahamedshanto@gmail.com",
    "url": "https://github.com/mdtanvirahamedshanto"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mdtanvirahamedshanto/bd-geo-info.git"
  },
  "bugs": {
    "url": "https://github.com/mdtanvirahamedshanto/bd-geo-info/issues"
  },
  "homepage": "https://github.com/mdtanvirahamedshanto/bd-geo-info#readme",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@swc/core": "^1.10.18",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "tsup": "^7.2.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "jest": "^29.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  }
}

{
  "name": "bd-geo-info",
  "version": "5.0.1",
  "description": "Bangladesh Geo Address** is a comprehensive JavaScript/TypeScript library for Bangladesh administrative and geographic data. Easily perform division, district, upazila (thana), union, village, and postal code lookups with official BBS geocode resolution, Bangla and English name support, and geolocation utilities. Designed for Node.js, and all major frontend and backend frameworks including React, Next.js, Vue, Angular, NestJS, Express, and Bun. Perfect for address forms, e-commerce, logistics, government services, GIS applications, data validation, location-based services, and Bangladesh-focused web and mobile applications. Lightweight, framework-agnostic, TypeScript-ready, and optimized for fast, reliable geographic data access.",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/esm/react/index.js",
      "require": "./dist/react/cjs/react/index.js",
      "types": "./dist/react/types/react/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm && npm run build:types && npm run build:react:cjs && npm run build:react:esm && npm run build:react:types && node scripts/minify-json.js",
    "build:cjs": "npx tsc -p tsconfig.cjs.json",
    "build:esm": "npx tsc -p tsconfig.esm.json",
    "build:types": "npx tsc -p tsconfig.types.json",
    "build:react:cjs": "npx tsc -p tsconfig.react.cjs.json",
    "build:react:esm": "npx tsc -p tsconfig.react.esm.json",
    "build:react:types": "npx tsc -p tsconfig.react.types.json",
    "test": "jest",
    "prepare": "npm run build"
  },
  "keywords": [
    "bangladesh",
    "geo",
    "division",
    "district",
    "upazila",
    "union",
    "postcode",
    "address",
    "bangla",
    "typescript",
    "react",
    "vue",
    "angular",
    "svelte",
    "nestjs",
    "nextjs",
    "framework-agnostic"
  ],
  "author": {
    "name": "Md Tanvir Ahamed Shanto",
    "email": "mdtanvirahamedshanto@gmail.com",
    "url": "https://github.com/mdtanvirahamedshanto"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mdtanvirahamedshanto/bd-geo-info.git"
  },
  "bugs": {
    "url": "https://github.com/mdtanvirahamedshanto/bd-geo-info/issues"
  },
  "homepage": "https://github.com/mdtanvirahamedshanto/bd-geo-info#readme",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@swc/core": "^1.10.18",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "tsup": "^7.2.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "jest": "^29.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  }
}
